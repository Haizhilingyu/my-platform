#!/bin/sh
# Pre-commit: 强制格式检查 + TDD 约束（后端 + 前端）

echo "🔍 Running pre-commit checks..."

# ============================================
# 后端检查
# ============================================
if [ -f backend/pom.xml ]; then
  echo "  [backend] Format check (Spotless)..."
  cd backend
  mvn spotless:check -q 2>/dev/null
  BACKEND_FMT=$?

  if [ $BACKEND_FMT -ne 0 ]; then
    echo "❌ Backend format check failed. Run: cd backend && mvn spotless:apply"
    exit 1
  fi

  echo "  [backend] Checkstyle..."
  mvn checkstyle:check -q 2>/dev/null
  BACKEND_CS=$?
  cd ..

  if [ $BACKEND_CS -ne 0 ]; then
    echo "❌ Backend checkstyle failed."
    exit 1
  fi

  echo "  [backend] Unit tests (changed modules only)..."
  cd backend
  mvn test -q -pl platform-common,modules/sys 2>/dev/null
  BACKEND_TEST=$?
  cd ..

  if [ $BACKEND_TEST -ne 0 ]; then
    echo "❌ Backend tests failed. Fix tests before committing."
    exit 1
  fi
fi

# ============================================
# 前端检查
# ============================================
if [ -f frontend/node_modules/.package-lock.json ]; then
  echo "  [frontend] Lint + Format..."
  cd frontend
  npx lint-staged
  FRONTEND_LINT=$?

  if [ $FRONTEND_LINT -ne 0 ]; then
    echo "❌ Frontend lint check failed."
    cd ..
    exit 1
  fi

  echo "  [frontend] Unit tests..."
  npx vitest run --reporter=verbose 2>&1 | tail -5
  FRONTEND_TEST=$?
  cd ..

  if [ $FRONTEND_TEST -ne 0 ]; then
    echo "❌ Frontend tests failed. Fix tests before committing."
    exit 1
  fi
fi

echo "✅ Pre-commit checks passed (format + lint + tests)."
