# ============================================================
# Docker Compose 部署环境变量样例
# ------------------------------------------------------------
# 复制本文件为 .env 并填入真实值，再执行 `docker compose up -d`。
#   cp docker/.env.example docker/.env
# .env 已被 .gitignore 忽略，不会进入版本库。
# ============================================================

# ---- PostgreSQL ----
# 数据库连接（默认指向 NAS 上的 PG 实例）
SPRING_DATASOURCE_URL=jdbc:postgresql://192.168.1.2:5532/platform
SPRING_DATASOURCE_USERNAME=postgres
# ⚠️ 必填：数据库密码（请勿提交到版本库）
SPRING_DATASOURCE_PASSWORD=

# ---- Redis ----
SPRING_DATA_REDIS_HOST=192.168.1.2
SPRING_DATA_REDIS_PORT=6380
# Redis 无密码则留空；NAS 上的 Redis 启用了认证，请填入
SPRING_DATA_REDIS_PASSWORD=

# ---- JWT ----
# ⚠️ 必填：JWT 签名密钥，长度 ≥ 32 字节。生产环境务必使用随机密钥
APP_SECURITY_JWT_SECRET=
